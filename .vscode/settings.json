{
    // ⚠️ 注意：密碼請勿寫死在此檔案中！
    // SQLTools 會在連線時提示輸入密碼，或使用 "askForPassword": true
    "sqltools.connections": [
        {
            "previewLimit": 50,
            "server": "hihi-memory.postgres.database.azure.com",
            "port": 5432,
            "driver": "PostgreSQL",
            "name": "HiHi Brain (SQLTools)",
            "database": "postgres",
            "username": "hi6688",
            "askForPassword": true,
            "pgOptions": {
                "ssl": {
                    "rejectUnauthorized": false
                }
            }
        }
    ],
    "database-client.connections": [
        {
            "name": "HiHi Brain (Database Client)",
            "driver": "PostgreSQL",
            "host": "hihi-memory.postgres.database.azure.com",
            "port": 5432,
            "user": "hi6688",
            "password": "",
            "database": "postgres",
            "ssl": true,
            "timezone": "+00:00"
        }
    ],
    "css.lint.unknownAtRules": "ignore",
    "terminal.integrated.profiles.linux": {
        "Gemini CLI": {
            "path": "/bin/bash",
            "args": ["-c", "gemini"],
            "icon": "sparkle",
            "color": "terminal.ansiCyan"
        }
    },

    // === Python 環境設定 ===
    // 使用 discord_bot 的虛擬環境作為預設 interpreter
    "python.defaultInterpreterPath": "${workspaceFolder}/discord_bot/.venv/bin/python",
    // 讓 IDE 能解析各子專案之間的相對 import
    "python.analysis.extraPaths": [
        "${workspaceFolder}/web_interface",
        "${workspaceFolder}/discord_bot",
        "${workspaceFolder}"
    ],
    // 不自動啟動虛擬環境（因為有多個子專案各有自己的 venv）
    "python.terminal.activateEnvironment": false
}
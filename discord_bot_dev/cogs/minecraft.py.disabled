import discord
from discord.ext import commands, tasks
from discord import app_commands
import asyncio
import os
import re
from dotenv import load_dotenv

# Load .env (from project root)
load_dotenv(os.path.join(os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__)))), '.env'))

# Server Settings
MC_DIR = os.getenv('MINECRAFT_DIR', "/home/terraria/servers/minecraft")
MC_SCREEN_NAME = os.getenv('MINECRAFT_SCREEN_NAME', "bedrock")
MC_CHANNEL_ID = int(os.getenv('DISCORD_LOG_CHANNEL_ID', '0')) # Switched to Admin Channel as requested
MC_LOG_FILE = os.path.join(MC_DIR, "bedrock_screen.log")

# Regex Patterns (Bedrock)
# [YYYY-MM-DD HH:MM:SS INFO] Player connected: Steve, xuid: ...
# regex[2026-02-04 04:11:25:574 INFO] Player Spawned: Hi66883843 xuid: ...
JOIN_PATTERN = re.compile(r'Player Spawned: (.+?)\s+xuid:')
LEFT_PATTERN = re.compile(r'Player disconnected: (.+), xuid:') # Keep disconnected check just in case, or use list changes
# List command output: There are 1/10 players online:
LIST_PATTERN = re.compile(r'There are (\d+)/(\d+) players online:')

# Regex: Capture [ChatLog] <Player> Message
# Log Line: [YYYY-MM-DD HH:MM:SS INFO] [ChatLog] <Hi6688> Hello World
CHAT_PATTERN = re.compile(r'\[ChatLog\]\s+<(.+?)>\s+(.*)')

class Minecraft(commands.Cog):
    """Minecraft Bedrock 伺服器整合模組"""

    def __init__(self, bot):
        self.bot = bot
        self.channel = None
        self.player_count = 0
        self.log_task = None
        
    @commands.Cog.listener()
    async def on_ready(self):
        print(f'🧱 Minecraft 模組已就緒 (Channel: {MC_CHANNEL_ID})')
        self.channel = self.bot.get_channel(MC_CHANNEL_ID)
        
        # Start log monitor if not already running
        if not self.log_task:
            self.log_task = self.bot.loop.create_task(self.read_log_loop())
            
        # Start status sync loop
        if not self.status_loop.is_running():
            self.status_loop.start()

    @commands.Cog.listener()
    async def on_message(self, message):
        if message.author.bot:
            return
        if message.channel.id != MC_CHANNEL_ID:
            return
            
        # Sync Discord Chat to Minecraft
        clean_msg = message.content.replace('"', '\\"')
        cmd = f'say <{message.author.display_name}> {clean_msg}'
        await self.send_command(cmd)

    async def send_command(self, cmd):
        # Send to screen session
        try:
            full_cmd = f"{cmd}\r"
            proc = await asyncio.create_subprocess_exec(
                "screen", "-S", MC_SCREEN_NAME, "-X", "stuff", full_cmd
            )
            await proc.wait()
        except Exception as e:
            print(f"[MC] Failed to send command: {e}")

    async def read_log_loop(self):
        """Real-time log monitoring using tail -f"""
        print(f"[MC] Started real-time log monitor: {MC_LOG_FILE}")
        if not os.path.exists(MC_LOG_FILE):
            print(f"[MC] Log file not found!")
            return

        try:
            # Use tail -f for instant updates
            process = await asyncio.create_subprocess_exec(
                'tail', '-f', '-n', '0', MC_LOG_FILE,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE
            )
            
            print("[MC] tail -f started - real-time monitoring active!")
            
            while True:
                line = await process.stdout.readline()
                if not line:
                    break
                    
                decoded_line = line.decode('utf-8', errors='replace').strip()
                await self.parse_line(decoded_line)
                
        except Exception as e:
            print(f"[MC] Log monitor error: {e}")
        finally:
            if process:
                process.kill()
                await process.wait()

    async def parse_line(self, line):
        if not line: return
        
        # DEBUG: Print line to help debug format
        print(f"[MC LOG] {line}")

        # Check for Join
        join_match = JOIN_PATTERN.search(line)
        if join_match:
            player = join_match.group(1)
            # Update count estimate
            self.player_count += 1
            if self.channel:
                await self.channel.send(f"🧱 **{player}** 加入了 Minecraft 伺服器（當前 {self.player_count} 人在線）")
            # Trigger list update to sync actual count
            await self.send_command("list")
            return

        # Check for Leave
        left_match = LEFT_PATTERN.search(line)
        if left_match:
            player = left_match.group(1)
            # Update count estimate
            self.player_count = max(0, self.player_count - 1)
            if self.channel:
                await self.channel.send(f"🧱 **{player}** 離開了 Minecraft 伺服器（當前 {self.player_count} 人在線）")
            # Trigger list update to sync actual count
            await self.send_command("list")
            return

        # Check for List Output (Player Count Update)
        list_match = LIST_PATTERN.search(line)
        if list_match:
            current, max_p = list_match.groups()
            self.player_count = int(current)
            return

        # Check for Chat
        # Avoid automated 'say' from Discord
        if "say <" in line: return 
        
        # Look for <Player> Message
        # We search the whole line
        match = CHAT_PATTERN.search(line)
        if match:
            user, msg = match.groups()
            if not user or not msg: return
            
            if self.channel:
                    await self.channel.send(f"🧱 **<{user}>** {msg}")

    @tasks.loop(minutes=2)
    async def status_loop(self):
        # Periodically ask for list to keep count updated
        await self.send_command("list")

    @app_commands.command(name="mc_status", description="[DEV] 查看 Minecraft 狀態")
    async def slash_mc_status(self, interaction: discord.Interaction):
        await interaction.response.send_message(f"🧱 Minecraft Bedrock | 👥 線上: {self.player_count}人", ephemeral=True)

async def setup(bot):
    await bot.add_cog(Minecraft(bot))

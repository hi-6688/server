# ============================================
# 環境變數範本 (.env.example)
# 複製此檔為 .env 並填入真實值
# cp .env.example .env
# ============================================

# --- Discord Bot Tokens ---
# 嗨嗨 (AI 聊天機器人)
DISCORD_TOKEN=你的_Discord_Bot_Token
# 神奇嗨螺 (功能型機器人：MC/Terraria 管理)
CONCH_TOKEN=你的_Conch_Bot_Token

# --- Discord 頻道 ID ---
# 泰拉瑞亞頻道 (遊戲內容: 玩家加入/離開、聊天)
TERRARIA_CHANNEL_ID=你的頻道ID
# 測試/日誌頻道 (系統訊息: 開機、關機、錯誤)
DISCORD_LOG_CHANNEL_ID=你的頻道ID
# Minecraft 頻道 (Minecraft 聊天、玩家進出)
MINECRAFT_CHANNEL_ID=你的頻道ID

# --- AI 設定 ---
GEMINI_API_KEY=你的_Gemini_API_Key
AI_MODEL_NAME=gemini-2.5-flash
# 活動區域：以逗號分隔多個頻道 ID
AI_CHANNEL_ID=頻道ID_1,頻道ID_2

# --- 資料庫 ---
# Azure PostgreSQL 連線字串
DATABASE_URL=postgres://使用者:密碼@主機:5432/資料庫名?sslmode=require
